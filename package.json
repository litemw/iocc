{
  "name": "@litemw/iocc",
  "version": "0.0.6",
  "author": "VladDotH",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/litemw/iocc.git"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "devDependencies": {
    "@types/bun": "1.3.11",
    "@types/node": "25.5.2",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "8.58.0",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.1",
    "rimraf": "^6.1.3",
    "tsafe": "1.8.12",
    "typescript": "6.0.2"
  },
  "peerDependencies": {},
  "exports": {
    "import": "./dist/index.mjs",
    "require": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "bugs": {
    "url": "https://github.com/litemw/iocc/issues"
  },
  "description": "IOC container for litemw ecosystem",
  "directories": {
    "lib": "lib"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.mjs",
    "dist/**/*.d.ts"
  ],
  "homepage": "https://github.com/litemw/iocc#readme",
  "license": "MIT",
  "lint-staged": {
    "**/*.ts": "eslint --fix --cache"
  },
  "peerDependenciesMeta": {},
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:dts": "tsc --build tsconfig.build.json --force",
    "build:cjs": "bun build lib/index.ts --outfile=dist/index.js --packages external --format cjs\n",
    "build:esm": "bun build lib/index.ts --outfile=dist/index.mjs --packages external --format esm",
    "build": "bun run build.ts",
    "postbuild": "rimraf tsconfig.build.tsbuildinfo",
    "lint": "bun run eslint ./**/*.ts --cache --no-warn-ignored",
    "lint:fix": "bun run lint --fix --cache --no-warn-ignored",
    "prepare": "bunx husky"
  },
  "types": "dist/index.d.ts"
}
