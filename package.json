{
  "name": "@litemw/iocc",
  "version": "0.0.2",
  "author": "VladDotH",
  "license": "MIT",
  "description": "IOC container for litemw ecosystem",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/litemw/iocc.git"
  },
  "bugs": {
    "url": "https://github.com/litemw/iocc/issues"
  },
  "homepage": "https://github.com/litemw/iocc#readme",
  "scripts": {
    "build:dts": "tsc --build tsconfig.build.json",
    "build:cjs": "bun build lib/index.ts --outfile=dist/index.js --packages external --format cjs\n",
    "build:esm": "bun build lib/index.ts --outfile=dist/index.mjs --packages external --format esm",
    "build": "bun run build.ts",
    "postbuild": "rimraf tsconfig.types.tsbuildinfo",
    "lint": "bun run eslint ./**/*.ts --cache",
    "lint:fix": "bun run lint --fix --cache"
  },
  "dependencies": {

  },
  "devDependencies": {
    "@types/bun": "1.2.1",
    "@types/node": "20.17.16",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "@typescript-eslint/parser": "5.62.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "8.10.0",
    "eslint-plugin-prettier": "4.2.1",
    "prettier": "2.8.8",
    "tsafe": "1.8.5",
    "typescript": "5.7.3"
  },
  "peerDependencies": {},
  "peerDependenciesMeta": {},
  "files": [
    "dist/**/*.js",
    "dist/**/*.mjs",
    "dist/**/*.d.ts"
  ],
  "module": "dist/index.mjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "directories": {
    "lib": "lib"
  },
  "exports": {
    "import": "./dist/index.mjs",
    "require": "./dist/index.js",
    "types": "./dist/index.d.ts"
  }
}